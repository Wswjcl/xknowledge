# ============================================================================
# QAWiki Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# All variables are prefixed with QAWIKI_.

# ---- LLM ----
QAWIKI_LLM_MODEL=gpt-4o
QAWIKI_LLM_API_KEY=sk-your-key-here
QAWIKI_LLM_ENDPOINT=https://api.openai.com/v1

# Optional: fallback LLM
# QAWIKI_LLM_API_KEY_2=sk-your-fallback-key
# QAWIKI_LLM_ENDPOINT_2=https://your-api.com/v1

# ---- Embedding ----
QAWIKI_EMBEDDING_MODEL=text-embedding-3-small
# QAWIKI_EMBEDDING_API_KEY defaults to QAWIKI_LLM_API_KEY if unset
# QAWIKI_EMBEDDING_ENDPOINT defaults to QAWIKI_LLM_ENDPOINT if unset

# ---- Knowledge Base ----
QAWIKI_KB_DIR=./knowledge_bank

# ---- Phase I: Distillation ----
QAWIKI_ROLLOUTS_PER_SAMPLE=4
QAWIKI_INSIGHT_MAX_OPS=3
QAWIKI_INSIGHT_MAX_ITEMS=500
QAWIKI_LARGE_BATCH_SIZE=8

# ---- Phase II: Retrieval ----
QAWIKI_RETRIEVAL_TOP_K=5

# ---- Runtime ----
QAWIKI_NUM_WORKERS=4
QAWIKI_TEMPERATURE=0.6
